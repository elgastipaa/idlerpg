# Stitch API config (completa estos valores)
STITCH_BASE_URL=https://your-stitch-api.example.com
STITCH_TOKEN=replace-with-your-token
STITCH_PROJECT_ID=replace-with-your-project-id

# Opcional: si tu API usa rutas distintas al default
STITCH_LIST_PATH=/projects/{projectId}/prototypes
STITCH_DETAIL_PATH=/prototypes/{id}
